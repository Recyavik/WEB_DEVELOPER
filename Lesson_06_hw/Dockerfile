# FROM — указываем базовый образ, на основе которого строим наш
# python:3.12-slim — официальный образ Python версии 3.12, «slim» означает лёгкая версия (меньше ненужных пакетов)
FROM python:3.12-slim

# WORKDIR — устанавливаем рабочую директорию внутри контейнера
# Все последующие команды будут выполняться из папки /app
# Если папки нет — Docker создаст её автоматически
WORKDIR /app

# COPY — копируем файлы с нашего компьютера в контейнер
# requirements.txt . — копируем только файл зависимостей в текущую папку (/app)
# Делаем это ДО копирования кода, чтобы Docker кэшировал слой с установкой пакетов
COPY requirements.txt .

# RUN — выполняем команду внутри контейнера во время сборки образа
# pip install — устанавливает Python-пакеты из requirements.txt
# --no-cache-dir — не сохранять кэш pip, чтобы образ занимал меньше места
# -r requirements.txt — читать список пакетов из файла requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# COPY . . — копируем весь остальной код из нашей папки в /app контейнера
# Первая точка — источник (текущая папка на нашем компьютере)
# Вторая точка — назначение (текущая рабочая папка /app внутри контейнера)
COPY . .

# CMD — команда, которая запустится когда контейнер стартует
# uvicorn — веб-сервер для запуска FastAPI-приложений
# app.main:app — путь к объекту приложения: файл app/main.py, переменная app
# --host 0.0.0.0 — слушать на всех сетевых интерфейсах (доступно снаружи контейнера)
# --port 8000 — порт, на котором будет работать сервер
# --reload — автоматически перезапускать при изменении кода (удобно при разработке)
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
