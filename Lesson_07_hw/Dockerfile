# ─── Dockerfile ────────────────────────────────────────────────────────────
# Dockerfile — инструкция для Docker: как собрать образ (image) контейнера.
# Образ — это как «снимок» системы с Python, зависимостями и нашим кодом.
# Из образа Docker запускает контейнер — изолированный процесс.

# FROM — выбираем базовый образ (готовую ОС + Python).
# python:3.12-slim — официальный образ Python версии 3.12.
# «slim» означает урезанная версия: весит меньше, нет лишних утилит.
FROM python:3.12-slim

# WORKDIR — устанавливает рабочую директорию внутри контейнера.
# Все последующие команды будут выполняться из папки /app.
# Если папка не существует — Docker создаёт её автоматически.
WORKDIR /app

# COPY requirements.txt . — копирует ТОЛЬКО файл зависимостей первым.
# Точка «.» означает «в текущую директорию» (т.е. в /app).
# Это важный приём: Docker кеширует каждый шаг (слой).
# Если код изменился, но requirements.txt — нет,
# Docker не будет заново устанавливать зависимости (используется кеш).
COPY requirements.txt .

# RUN — выполняет команду во время сборки образа.
# pip install -r requirements.txt — устанавливает все библиотеки из файла.
# --no-cache-dir — не сохранять кеш pip, чтобы образ весил меньше.
RUN pip install --no-cache-dir -r requirements.txt

# COPY . . — копирует ВСЕ файлы проекта (из текущей папки на хосте)
# в /app внутри контейнера. Это делается ПОСЛЕ установки зависимостей,
# чтобы изменение кода не сбрасывало кеш зависимостей.
COPY . .

# CMD — команда, которая запускается при старте контейнера (не при сборке).
# Здесь две команды через &&:
# 1. alembic upgrade head — применяет все миграции к базе данных
#    (создаёт/обновляет таблицы). Если миграции уже применены — пропускает.
# 2. uvicorn app.main:app — запускает веб-сервер.
#    app.main  — путь к файлу: папка app, файл main.py
#    :app      — имя переменной FastAPI-приложения внутри main.py
#    --host 0.0.0.0 — слушать все сетевые интерфейсы (не только localhost),
#                     иначе к контейнеру нельзя будет подключиться снаружи.
#    --port 8000    — номер порта, на котором работает сервер.
#    --reload       — перезапускать сервер при изменении файлов (удобно при разработке).
CMD alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
